server {
    listen 80;
    server_name localhost;

    location /staticfiles/ {
        root /usr/src/gmod-logs-server/gmodlogs;
    }
    location /media/ {
        root /usr/src/gmod-logs-server/gmodlogs;
    }

    location / {
        include proxy_params;
        proxy_pass http://unix:/usr/src/gmod-logs-server/gmodlogs.sock;
    }
}
